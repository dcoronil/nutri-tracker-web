OPENFOODFACTS_BASE_URL=https://world.openfoodfacts.org/api/v2
OCR_LANG=eng+spa
AUTH_SECRET_KEY=change-me-in-production
AUTH_TOKEN_TTL_HOURS=720
VERIFICATION_CODE_TTL_MINUTES=15
SMTP_HOST=
